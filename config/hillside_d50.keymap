/* Hillside Dactyl 50 keymap entry point.
 *
 * base.keymap defines a 34-key layout (30 alpha + 4 thumb). The D50 has 50
 * physical keys, so we wrap the base layout with 16 extra slots, all
 * defaulting to &none. Override any of the X_* macros below to bind keys —
 * the bindings apply across every layer in base.keymap.
 *
 * The 50 physical keys break down as:
 *   30 alpha             (3 rows × 5 cols × 2 sides)         — base.keymap LT/RT/LM/RM/LB/RB
 *    6 outer pinky col   (1 extra col per side, 3 rows tall) — X_LT/X_LM/X_LB and X_RT/X_RM/X_RB
 *    4 alpha extras      (raised pair under each cluster,    — X_LL[2..3] and X_RL[0..1]
 *                         reached by index/middle finger —
 *                         NOT thumb keys)
 *   10 thumb cluster     (5 per side: 2 bot-corner +         — X_LL[0..1]/X_RL[2..3]/X_LH/
 *                         3 inner-cluster thumbs)              X_RH plus base.keymap LH/RH
 *
 * Full layout (top-down view, matches the d50_both_above reference photo).
 * The pinky home column is LT4/RT4 (= Q/' in Colemak-DH). X_LT/X_LM/X_LB
 * and X_RT/X_RM/X_RB are the *second* pinky column — a stretch reach outward
 * from the home pinky. On temper these don't exist, so binding choices are
 * fresh (common picks: Tab, Esc, Backspace, sticky modifiers).
 *
 *   alpha cluster + outer pinky column
 *   ╭──────────────────────────────╮       ╭──────────────────────────────╮
 *   │ X_LT  LT4  LT3  LT2  LT1 LT0 │       │ RT0  RT1  RT2  RT3  RT4 X_RT │  row 0
 *   │ X_LM  LM4  LM3  LM2  LM1 LM0 │       │ RM0  RM1  RM2  RM3  RM4 X_RM │  row 1
 *   │ X_LB  LB4  LB3  LB2  LB1 LB0 │       │ RB0  RB1  RB2  RB3  RB4 X_RB │  row 2
 *   ╰──────────────────────────────╯       ╰──────────────────────────────╯
 *
 *   raised alpha extras (between halves, under inner alpha cols, reached by
 *   index/middle finger curling down — these are NOT thumb keys):
 *                       ┌──────────┐  ┌──────────┐
 *                       │ X_LL[2]  │  │ X_RL[0]  │
 *                       │ X_LL[3]  │  │ X_RL[1]  │
 *                       └──────────┘  └──────────┘
 *
 *   bot-corner thumbs (under outer alpha cols 2–3 of each half, NOT in the
 *   gap — they sit directly below the alpha cluster):
 *
 *   ┌──────────┐                                              ┌──────────┐
 *   │ X_LL[0]  │                                              │ X_RL[2]  │
 *   │ X_LL[1]  │                                              │ X_RL[3]  │
 *   └──────────┘                                              └──────────┘
 *
 *   inner thumb cluster (6 keys curving across the gap, 3 per side):
 *
 *               ┌──────┐ ┌──────┐ ┌──────┐ ┌──────┐ ┌──────┐ ┌──────┐
 *               │ X_LH │ │LH[0] │ │LH[1] │ │RH[0] │ │RH[1] │ │ X_RH │
 *               │outer │ │middle│ │inner │ │inner │ │middle│ │outer │
 *               └──────┘ └──────┘ └──────┘ └──────┘ └──────┘ └──────┘
 *                  ↑       ↑        ↑         ↑       ↑         ↑
 *              outermost  Space   Return  SMART_NUM MAGIC_  outermost
 *                left     (lt_spc (lt FN              SHIFT  right
 *                         NAV)    RET)
 *
 * Slot summary (per side):
 *
 *   LEFT THUMB CLUSTER                  RIGHT THUMB CLUSTER (mirror)
 *   ──────────────────                  ────────────────────────────
 *   X_LL[0]  bot-corner outer RC(3,2)   X_RL[2]  bot-corner near   RC(3,8)
 *   X_LL[1]  bot-corner near  RC(3,3)   X_RL[3]  bot-corner outer  RC(3,9)
 *   X_LH     outer thumb      RC(4,5)   RH[0]    inner-most thumb  RC(4,8) = SMART_NUM
 *   LH[0]    middle thumb     RC(4,4)   RH[1]    middle thumb      RC(4,7) = MAGIC_SHIFT
 *   LH[1]    inner-most thumb RC(4,3)   X_RH     outer thumb       RC(4,6)
 *               (LH[0]/LH[1] = &lt_spc NAV / &lt FN RET from base.keymap)
 *
 * X_LL macro-arg order:  X_LL[0] X_LL[1] X_LL[2] X_LL[3]
 *                        bot-out bot-in  raised  raised
 *                        (thumb) (thumb) (alpha) (alpha)
 * X_RL macro-arg order:  X_RL[0] X_RL[1] X_RL[2] X_RL[3]
 *                        raised  raised  bot-in  bot-out
 *                        (alpha) (alpha) (thumb) (thumb)
 */

#define CONFIG_WIRELESS

/* Second (outer) pinky column — 1 binding each. Physical keys exist on
 * this build; bindings TBD. Common choices: Tab, Esc, Backspace, sticky
 * mods. */
#define X_LT &none
#define X_RT &none
#define X_LM &none
#define X_RM &none
#define X_LB &none
#define X_RB &none

/* Outer-most thumbs (1 each side) — outside RH/LH from base.keymap. */
#define X_LH &none
#define X_RH &none

/* X_LL/X_RL — 4 bindings each, mixed: first two are alpha extras (raised
 * pair, reached by index/middle finger), last two are thumb-cluster keys
 * on the right; left mirrors the order. See header for details. */
#define X_LL &none &none &none &none
#define X_RL &none &none &none &none

#define ZMK_BASE_LAYER(name, LT, RT, LM, RM, LB, RB, LH, RH)                   \
    ZMK_LAYER(                                                                 \
        name,                                                                  \
        X_LT  LT          RT  X_RT                                             \
        X_LM  LM          RM  X_RM                                             \
        X_LB  LB          RB  X_RB                                             \
        X_LL              X_RL                                                 \
        X_LH  LH          RH  X_RH                                             \
    )

#include "key-labels/hillside_d50.h"
#include "base.keymap"
